# ── inMotion MCP server configuration ───────────────────────────────────────
# Copy to `.env` and fill in. Every service is optional; tools for an
# unconfigured service return a clear "not configured" error instead of failing.

# Notion (CRM / system-of-record)
NOTION_TOKEN=
NOTION_LEADS_DATABASE_ID=

# n8n (automation layer)
#   N8N_BASE_URL is the API root, e.g. https://your-n8n-host/api/v1
#   N8N_WEBHOOK_BASE_URL is the host serving webhooks, e.g. https://your-n8n-host
N8N_BASE_URL=
N8N_API_KEY=
N8N_WEBHOOK_BASE_URL=

# Gmail (outbound layer) - short-lived OAuth2 access token with Gmail scopes
GMAIL_ACCESS_TOKEN=
GMAIL_SENDER=

# Optional: per-request HTTP timeout in seconds (default 30)
MCP_HTTP_TIMEOUT=30
